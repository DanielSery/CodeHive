{
  "name": "codehive",
  "version": "0.3.12",
  "description": "CodeHive - VS Code workspace manager with bare repo/worktree workflow",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win --dir",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "build": {
    "appId": "com.codehive.app",
    "productName": "CodeHive",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "index.html",
      "styles.css",
      "node_modules/**/*",
      "vscode-data/**/*",
      "CodeHive.ico"
    ],
    "win": {
      "target": [
        "dir"
      ],
      "icon": "CodeHive.ico",
      "electronLanguages": [
        "en-US"
      ]
    }
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^25.0.1",
    "puppeteer-core": "^24.40.0",
    "vitest": "^2.1.9"
  }
}
