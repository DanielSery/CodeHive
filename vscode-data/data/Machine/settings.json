{
  "telemetry.telemetryLevel": "off",
  "workbench.startupEditor": "newUntitledFile",
  "workbench.colorTheme": "Catppuccin Mocha",
  "workbench.iconTheme": "catppuccin-mocha",
  "workbench.startupViewActivity": "claude-sidebar",
  "chat.enabled": false,
  "github.copilot.enable": false,
  "git.enableSmartCommit": true,
  "git.smartCommitChanges": "all",
  "workbench.sideBar.location": "left",
  "workbench.activityBar.location": "top",
  "window.titleBarStyle": "native",
  "workbench.layoutControl.enabled": false,
  "claudeCode.preferredLocation": "sidebar",
  "explorer.autoReveal": true,
  "explorer.sortOrder": "type",
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "workbench.statusBar.visible": false,
  "window.density.editorTabHeight": "compact",
  "window.density.styles.activityBar": "compact",
  "window.density.styles.sidebar": "compact",
  "window.density.styles.panel": "compact",
  "workbench.editor.tabSizing": "shrink",
  "workbench.editor.labelFormat": "short",
  "workbench.editor.customLabels.enabled": true,
  "workbench.editor.customLabels.patterns": {
    "**/*.css": "${filename}.${extname}",
    "**/*.cs": "${filename}",
    "**/*.xaml": "${filename}",
    "**/*.json": "${filename}"
  },
  "workbench.tree.indent": 12,
  "workbench.tree.renderIndentGuides": "always",
  "workbench.list.openMode": "singleClick",
  "window.density.styles.breadcrumbs": "compact",
  "window.density.styles.tabs": "compact",
  "workbench.auxiliaryBar.visible": true,
  "editor.minimap.enabled": false,
  "workbench.secondarySideBar.visible": true,
  "dotnet.backgroundAnalysis.analyzerDiagnosticsScope": "openFiles",
  "dotnet.backgroundAnalysis.compilerDiagnosticsScope": "openFiles",
  "csharp.inlayHints.enableInlayHintsForImplicitObjectCreation": false,
  "csharp.inlayHints.enableInlayHintsForImplicitVariableTypes": false,
  "csharp.inlayHints.enableInlayHintsForLambdaParameterTypes": false,
  "csharp.inlayHints.enableInlayHintsForTypes": false,
  "dotnet.codeLens.enableReferencesCodeLens": false,
  "dotnet.codeLens.enableTestsCodeLens": false,
  "quickInput.position": "center",
  "window.quickOpen.position": "center",
}
